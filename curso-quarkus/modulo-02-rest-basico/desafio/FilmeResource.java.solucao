    public Long id;
    public String nome;
    public Integer ano;
    public String diretor;
    public Double nota;

    public Filme() {}

    public Filme(Long id, String nome, Integer ano, String diretor, Double nota) {
        this.id = id;
        this.nome = nome;
        this.ano = ano;
        this.diretor = diretor;
        this.nota = nota;
    }
}
